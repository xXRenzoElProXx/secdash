# ========================================
# CONFIGURACIÓN SECDASH - SecDash AI SOC
# ========================================

# === MODO DE OPERACIÓN ===
# Por defecto: true (datos reales)
# Para modo demo/presentación: false
USE_REAL_APIS=true

# === API KEYS EXTERNAS ===
# Obtener en: https://nvd.nist.gov/developers/request-an-api-key
# Opcional - sin key funciona en modo rate-limitado (más lento)
NVD_API_KEY=

# Obtener en: https://www.abuseipdb.com/api
# Opcional - sin key usa análisis local básico
ABUSEIPDB_API_KEY=

# === CONFIGURACIÓN IA ===
# Por defecto usa Ollama local (http://localhost:11434)
USE_OLLAMA=true

# Si usas OpenAI en lugar de Ollama (no recomendado - costoso)
# OPENAI_API_KEY=sk-...

# === NOTAS ===
# 1. Copia este archivo a ".env" y completa las variables
# 2. Las API keys son OPCIONALES - el sistema funciona sin ellas
# 3. Sin API keys:
#    - AG7 consulta NVD sin autenticación (rate limitado)
#    - AG8 usa análisis local de IPs
#    - AG11 usa datos de EPSS mock
# 4. Con API keys:
#    - AG7 consulta NVD con prioridad (sin rate limits)
#    - AG8 verifica IPs en AbuseIPDB (datos reales de reputación)
#    - AG11 consulta EPSS real de FIRST.org
